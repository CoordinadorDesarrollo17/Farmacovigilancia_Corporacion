<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Sln_Farmacovigilancia_v2.styles.css" asp-append-version="true" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3 rounded-bottom-5 fixed-top">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center me-4" asp-area="" asp-controller="Home" asp-action="Index" style="padding-left:5%;">
                    <img src="~/img/LOGO CORPORACIÓN COBEFAR.png" alt="Cobefar" width="150" height="80" style="object-fit:contain;">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav nav-underline2 mx-auto gap-lg-4 gap-2">
                        <li class="nav-item">
                            <a class="nav-link " asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index", "Home")#nosotros">Nosotros</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link " href="@Url.Action("Index", "Home")#certificaciones">Certificaciones</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link " asp-area="" asp-controller="Home" asp-action="farmacovigilancia">Farmacovigilancia</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link " asp-area="" asp-controller="Home" asp-action="productos">Productos</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
  

    <div class="container-fluid px-0">
        <main role="main" >
            @RenderBody()
        </main>
    </div>

    <footer class="footer-cobefar pt-5 pb-4">
        <div class="container">
            <div class="row align-items-start gy-4">
                <div class="col-lg-4">
                    <div class="w-100 rounded-4 overflow-hidden d-flex justify-content-center ">
                        <img src="/img/LOGO CORP. VERSIÓN 2 BLANCO.png" class="img-fluid" style="max-width: 250px;" alt="footer">
                    </div>
                </div>
                <div class="col-lg-4">
                    <h6 class="fw-bold mb-3">Dirección</h6>
                    <p class="mb-1 small">
                        Cal. Carlos Pedemonte N° 128-132 MZ.C, Lote.04, 2° Piso
                    </p>
                    <p class="mb-1 small">
                        Urb. El mercurio 
                    </p>
                    <p class="mb-0 small">
                        San Luis - Lima - Perú
                    </p>

                    <h6 class="fw-bold mt-4 mb-2">Correo</h6>

                    <a href="mailto:atencionalcliente@corporacioncobefar.com.pe"
                       class="d-block mb-1 small text-white text-decoration-none">
                        atencionalcliente@corporacioncobefar.com.pe
                    </a>

                    <a href="mailto:fv@corporacioncobefar.com.pe"
                       class="d-block mb-1 small text-white text-decoration-none">
                        fv@corporacioncobefar.com.pe
                    </a>

                    <a href="mailto:dtecnica@corporacioncobefar.com.pe"
                       class="d-block mb-0 small text-white text-decoration-none">
                        dtecnica@corporacioncobefar.com.pe
                    </a>


                </div>

                <div class="col-lg-4">
                    <h6 class="fw-bold mb-3">Teléfono</h6>
                    <p class="mb-2 small">
                        Ventas: 960-277-639
                    </p>
                    <p class="mb-0 small">
                        Farmacovigilancia: 922-528-370
                    </p>
                </div>
            </div>
        </div>
    </footer>
  
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
